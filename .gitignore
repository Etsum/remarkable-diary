# Python
__pycache__/
*.py[cod]
.venv/

# Build artifacts (setuptools editable install)
build/
*.egg-info/

# Generated output — produced client-side at build time, never committed.
# (PDFs + blank/preview PNGs.)
out/
*.pdf
*.png

# NOTE: the SVG masters in templates/ ARE tracked (they are the source of
# truth / generator input) — .svg is intentionally not ignored.
